# ============================================================================
# Raji Backend — .env.example
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in. NEVER commit real values.
# Edge Functions read these via `Deno.env.get(...)`.
# For production, set these as Supabase Function secrets:
#   supabase secrets set ANTHROPIC_API_KEY=sk-...
# Source: RAJI-CONTEXT.md §D-09, expert-knowledge/05-security-privacy.md
# ============================================================================

# ---- Supabase (auto-populated by `supabase start` locally) -----------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic (Claude) ----------------------------------------------------
# Issued at https://console.anthropic.com. Server-side ONLY.
ANTHROPIC_API_KEY=
# Optional: override Anthropic-Version header.
ANTHROPIC_VERSION=2023-06-01

# ---- Sarvam (STT Saaras v2) ------------------------------------------------
# Request via Sarvam commercial onboarding (MASTER-ARCHITECTURE.md §5).
SARVAM_API_KEY=
# Default is https://api.sarvam.ai/speech-to-text; override if Sarvam changes.
SARVAM_STT_URL=

# ---- Optional tuning -------------------------------------------------------
# RATE_LIMIT_ANTHROPIC_PER_MIN=30
# RATE_LIMIT_SARVAM_PER_MIN=60
