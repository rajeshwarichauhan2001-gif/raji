{
  "//": "Deno config for Supabase Edge Functions (Raji backend). See RAJI-CONTEXT.md §D-09.",
  "compilerOptions": {
    "allowJs": false,
    "strict": true,
    "lib": ["deno.window", "dom"],
    "types": ["https://esm.sh/@supabase/supabase-js@2.45.4"]
  },
  "lint": {
    "include": ["supabase/functions/"],
    "exclude": ["supabase/functions/**/node_modules"],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any", "no-unused-vars"]
    }
  },
  "fmt": {
    "include": ["supabase/functions/"],
    "options": {
      "indentWidth": 2,
      "lineWidth": 100,
      "singleQuote": false,
      "semiColons": true
    }
  },
  "importMap": "./supabase/functions/import_map.json",
  "tasks": {
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check supabase/functions/**/*.ts"
  }
}
