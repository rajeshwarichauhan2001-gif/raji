# Raji — Root environment variables example
#
# This file documents environment variables needed across the whole project.
# For specific modules, see their individual .env.example files:
#   - backend/.env.example — Supabase Edge Functions secrets
#
# DO NOT commit real .env files. .gitignore already excludes them.

# --- Optional: local dev overrides ---
# Set these if you want local builds to use a non-default environment.

# RAJI_ENV=local               # one of: local, dev, staging, prod
# RAJI_BACKEND_URL=http://localhost:54321
# RAJI_LOG_LEVEL=debug
